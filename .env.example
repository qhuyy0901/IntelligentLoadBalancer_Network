# ─────────────────────────────────────────────────────────────────────────────
# IntelligentLoadBalancer — environment configuration
# Copy this file to .env and fill in your real values.
#
# DO NOT commit .env to git (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# AWS region where your resources live
AWS_REGION=ap-southeast-2

# Auto Scaling Group name (used to list EC2 instances)
AUTO_SCALING_GROUP_NAME=lb-asg

# ALB DNS (human-readable URL, used in dashboard display)
ALB_DNS=my-alb-2056764661.ap-southeast-2.elb.amazonaws.com

# Full ARN of the Target Group
# Find it in: AWS Console → EC2 → Target Groups → target-ec2 → Details tab
TARGET_GROUP_ARN=arn:aws:elasticloadbalancing:ap-southeast-2:123456789012:targetgroup/target-ec2/abcdef1234567890

# Full ARN of the Application Load Balancer
# Find it in: AWS Console → EC2 → Load Balancers → my-alb → Details tab
LOAD_BALANCER_ARN=arn:aws:elasticloadbalancing:ap-southeast-2:123456789012:loadbalancer/app/my-alb/abcdef1234567890

# ─── Polling / CloudWatch settings (optional, defaults shown) ──────────────

# How often the WebSocket server polls AWS (milliseconds, min 3000)
AWS_POLL_INTERVAL_MS=5000

# CloudWatch metric aggregation period in seconds
CLOUDWATCH_PERIOD_SECONDS=60

# How many minutes back to look for CloudWatch datapoints
CLOUDWATCH_LOOKBACK_MINUTES=10

# ─── Credentials ────────────────────────────────────────────────────────────
#
# PREFERRED (on EC2): attach an IAM Role to the EC2 instance — no keys needed.
# Required permissions (all read-only):
#   - ec2:DescribeInstances
#   - elasticloadbalancing:DescribeTargetGroups
#   - elasticloadbalancing:DescribeTargetHealth
#   - elasticloadbalancing:DescribeLoadBalancers
#   - autoscaling:DescribeAutoScalingGroups
#   - autoscaling:DescribeScalingActivities
#   - cloudwatch:GetMetricData
#
# ALTERNATIVE (local dev): set a named profile in ~/.aws/credentials
#   AWS_PROFILE=my-profile
#
# LAST RESORT: put access keys here (never commit to git)
#   AWS_ACCESS_KEY_ID=AKIAxxx
#   AWS_SECRET_ACCESS_KEY=xxx
